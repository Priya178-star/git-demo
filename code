3. Linear Search
✅ Java Code
package com.devops;

public class Search {

    public int linearSearch(int[] arr, int key) {
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == key)
                return i;
        }
        return -1;
    }
}
✅ JUnit Test
package com.devops;

import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;

class SearchTest {

    Search s = new Search();

    @Test
    void testFound() {
        assertEquals(2, s.linearSearch(new int[]{10,20,30}, 30));
    }

    @Test
    void testNotFound() {
        assertEquals(-1, s.linearSearch(new int[]{10,20,30}, 50));
    }
}
