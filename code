import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.Test;

class CompareNumbersTest {

    CompareNumbers c = new CompareNumbers();

    @Test
    void testMax() {
        assertEquals(90, c.findMax(10, 90, 30));
    }
}
