4. Compare 3 Numbers (Highest Number)
✅ Java Code
package com.devops;

public class CompareNumbers {

    public int findMax(int a, int b, int c) {
        if (a >= b && a >= c)
            return a;
        else if (b >= a && b >= c)
            return b;
        else
            return c;
    }
}
✅ JUnit Test
